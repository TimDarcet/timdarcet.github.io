# build inputs & generated caches — not part of the deployed site
.ign-venv/
__pycache__/
*.pyc

# IGN BD TOPO source archive + extraction (build_ign.py input; re-downloadable)
bdtopo_d075.7z
bdtopo_d075_extracted/

# OSM Overpass raw caches (build.py input; re-fetched if absent)
paris_raw.json
arr_raw.json
plaza_raw.json

# Paris Open Data quartier boundaries (build_areas.py input; re-fetched if absent)
quartiers.geojson

# Paris Open Data commemorative plaques raw API cache (build_plaques.py input; re-fetched if absent)
plaques_raw.json

# Sucettes "Histoire de Paris" pipeline: raw fetch cache, intermediate stage data, OCR language models
# (all re-fetchable build inputs; the deployed output sucettes.js IS committed)
sucettes/cache/
sucettes/data/
sucettes/tessdata/
# ...except the VLM transcriptions: hand-produced by vision, not re-fetchable, so keep them
!sucettes/data/vlm.json

